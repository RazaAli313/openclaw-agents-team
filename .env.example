# ============================================================
# OpenClaw 4-Agent System — Environment Variables
# setup.sh prompts for each. Press Enter to skip optional ones.
# ============================================================

# LLM — pick one during setup (MiniMax, Gemini, or OpenAI)
MINIMAX_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Commander — Notion (reads tasks, no database ID needed)
NOTION_API_KEY=

# Research — YouTube Data API + Brave Search
YOUTUBE_API_KEY=
BRAVE_SEARCH_API_KEY=

# Content — OpenAI (DALL-E image generation; reuse OPENAI_API_KEY if OpenAI chosen as LLM)
# OPENAI_API_KEY above

# Performance — Stripe (read-only: MRR, subscriptions, revenue). Optional.
STRIPE_SECRET_KEY=

# Infrastructure — Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Infrastructure — Google (Gmail + Drive)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
